---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:news="http://www.google.com/schemas/sitemap-news/0.9"
        xmlns:image="http://www.google.com/schemas/sitemap-image/1.1">

  <!-- Homepage -->
  <url>
    <loc>{{ site.url }}/</loc>
    <changefreq>always</changefreq>
    <priority>1.0</priority>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
  </url>

  <!-- Category pages -->
  {% for cat_pair in site.data.categories %}
  <url>
    <loc>{{ site.url }}/{{ cat_pair[0] }}/</loc>
    <changefreq>hourly</changefreq>
    <priority>0.8</priority>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
  </url>
  {% endfor %}

  <!-- Posts (newest = highest priority; news:news only on items < 48h old) -->
  {% assign news_cutoff = site.time | date: '%s' | minus: 172800 %}
  {% assign now_ts = site.time | date: '%s' | plus: 0 %}
  {% for post in site.posts %}
    {% if forloop.index <= 10 %}
      {% assign priority = "0.9" %}
    {% elsif forloop.index <= 50 %}
      {% assign priority = "0.7" %}
    {% else %}
      {% assign priority = "0.5" %}
    {% endif %}
    {% assign post_ts = post.date | date: '%s' | plus: 0 %}
    {% assign age_days = now_ts | minus: post_ts | divided_by: 86400 %}
    {% if age_days < 1 %}{% assign cf = "hourly" %}
    {% elsif age_days < 7 %}{% assign cf = "daily" %}
    {% elsif age_days < 30 %}{% assign cf = "weekly" %}
    {% else %}{% assign cf = "monthly" %}{% endif %}
  <url>
    <loc>{{ post.url | absolute_url }}</loc>
    <lastmod>{% if post.last_modified_at %}{{ post.last_modified_at | date_to_xmlschema }}{% else %}{{ post.date | date_to_xmlschema }}{% endif %}</lastmod>
    <changefreq>{{ cf }}</changefreq>
    <priority>{{ priority }}</priority>
    {% if post.image %}
    <image:image>
      <image:loc>{% if post.image contains 'http' %}{{ post.image }}{% else %}{{ post.image | absolute_url }}{% endif %}</image:loc>
      <image:title>{{ post.title | escape }}</image:title>
      {% if post.image_caption %}<image:caption>{{ post.image_caption | escape }}</image:caption>{% endif %}
    </image:image>
    {% endif %}
    {% if post_ts >= news_cutoff %}
    <news:news>
      <news:publication>
        <news:name>{{ site.title }}</news:name>
        <news:language>{{ post.lang | default: 'en' }}</news:language>
      </news:publication>
      <news:publication_date>{{ post.date | date_to_xmlschema }}</news:publication_date>
      <news:title>{{ post.title | escape }}</news:title>
      {% if post.keywords %}
      <news:keywords>{{ post.keywords | join: ", " }}</news:keywords>
      {% elsif post.tags.size > 0 %}
      <news:keywords>{{ post.tags | join: ", " }}</news:keywords>
      {% endif %}
    </news:news>
    {% endif %}
  </url>
  {% endfor %}

</urlset>
