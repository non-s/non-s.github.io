---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xhtml="http://www.w3.org/1999/xhtml">
  {% comment %}
    Portuguese sitemap. Lists every translated post (lang == "pt-br")
    plus the PT landing page when it exists.
  {% endcomment %}
  <url>
    <loc>{{ site.url }}/pt/</loc>
    <changefreq>hourly</changefreq>
    <priority>0.9</priority>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
  </url>
  {% for post in site.posts %}
  {% if post.lang == "pt-br" %}
  <url>
    <loc>{{ post.url | absolute_url }}</loc>
    <lastmod>{{ post.date | date_to_xmlschema }}</lastmod>
    <changefreq>never</changefreq>
    <priority>0.7</priority>
    {% if post.translated_from %}
      {% assign en_filename = post.translated_from %}
      {% assign en_match = site.posts | where_exp: "p", "p.path contains en_filename" | first %}
      {% if en_match %}
        <xhtml:link rel="alternate" hreflang="en" href="{{ en_match.url | absolute_url }}" />
      {% endif %}
    {% endif %}
    <xhtml:link rel="alternate" hreflang="pt-BR" href="{{ post.url | absolute_url }}" />
  </url>
  {% endif %}
  {% endfor %}
</urlset>
