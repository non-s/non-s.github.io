---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0" xmlns:media="http://search.yahoo.com/mrss/" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>GlobalBR News — War</title>
    <link>{{ site.url }}/war/</link>
    <description>Latest War &amp; Conflict news from GlobalBR News</description>
    <atom:link href="{{ '/feed/war.xml' | absolute_url }}" rel="self" type="application/rss+xml"/>
    {% assign cat_posts = site.posts | where_exp: "p", "p.categories contains 'war'" | limit: 20 %}
    {% for post in cat_posts %}
    <item>
      <title>{{ post.title | xml_escape }}</title>
      <link>{{ post.url | absolute_url }}</link>
      <description>{{ post.description | xml_escape }}</description>
      <pubDate>{{ post.date | date_to_rfc822 }}</pubDate>
      <guid>{{ post.url | absolute_url }}</guid>
      {% if post.image %}<media:content url="{{ post.image }}" medium="image"/>{% endif %}
    </item>
    {% endfor %}
  </channel>
</rss>
