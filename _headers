# IMPORTANT: GitHub Pages ignores this file — it's a Netlify/Cloudflare
# Pages convention. The security headers below are also emitted from
# `_includes/head.html` via `<meta http-equiv>` so they actually apply
# on the live (GitHub Pages) deploy. Keep them in sync. If/when the
# site moves behind Cloudflare or Netlify, the _headers entries take
# over and you can drop the meta-tag duplicates (meta-CSP can't set
# frame-ancestors, report-uri, or sandbox — real headers can).

/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://pagead2.googlesyndication.com https://cdn.jsdelivr.net https://giscus.app https://www.clarity.ms; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://fonts.googleapis.com https://giscus.app; img-src 'self' data: https: blob:; font-src 'self' https://fonts.gstatic.com https://cdn.jsdelivr.net; frame-src https://www.youtube.com https://www.youtube-nocookie.com https://giscus.app; media-src 'self' https:; connect-src 'self' https://www.google-analytics.com https://api.coingecko.com https://hacker-news.firebaseio.com https://giscus.app https://www.clarity.ms;

/assets/audio/*
  Content-Type: audio/mpeg
  Cache-Control: public, max-age=2592000, immutable

/assets/css/*
  Cache-Control: public, max-age=2592000, immutable

/assets/js/*
  Cache-Control: public, max-age=2592000, immutable

/assets/images/*
  Cache-Control: public, max-age=2592000, immutable

/sitemap*.xml
  Cache-Control: public, max-age=3600

/feed*.xml
  Cache-Control: public, max-age=600

/feed.json
  Cache-Control: public, max-age=600

/search-index.json
  Cache-Control: public, max-age=600
