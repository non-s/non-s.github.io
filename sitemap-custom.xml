---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <!-- Home page: highest priority -->
  <url>
    <loc>{{ site.url }}/</loc>
    <changefreq>always</changefreq>
    <priority>1.0</priority>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
  </url>
  <!-- Category pages: high priority -->
  {% for cat in site.data.categories %}
  <url>
    <loc>{{ site.url }}/{{ cat[0] }}/</loc>
    <changefreq>hourly</changefreq>
    <priority>0.8</priority>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
  </url>
  {% endfor %}
  <!-- Posts: medium priority, higher for recent -->
  {% for post in site.posts %}
  {% assign post_ts = post.date | date: '%s' | plus: 0 %}
  {% assign now_ts = site.time | date: '%s' | plus: 0 %}
  {% assign age_seconds = now_ts | minus: post_ts %}
  {% assign age_days = age_seconds | divided_by: 86400 %}
  <url>
    <loc>{{ post.url | absolute_url }}</loc>
    <changefreq>{% if age_days < 7 %}daily{% elsif age_days < 30 %}weekly{% else %}monthly{% endif %}</changefreq>
    <priority>{% if age_days < 1 %}0.9{% elsif age_days < 7 %}0.7{% elsif age_days < 30 %}0.5{% else %}0.3{% endif %}</priority>
    <lastmod>{{ post.date | date_to_xmlschema }}</lastmod>
  </url>
  {% endfor %}
  <!-- Static pages -->
  <url><loc>{{ site.url }}/about/</loc><changefreq>monthly</changefreq><priority>0.4</priority></url>
  <url><loc>{{ site.url }}/archive/</loc><changefreq>daily</changefreq><priority>0.6</priority></url>
  <url><loc>{{ site.url }}/tags/</loc><changefreq>daily</changefreq><priority>0.5</priority></url>
  <url><loc>{{ site.url }}/trending/</loc><changefreq>daily</changefreq><priority>0.6</priority></url>
  <url><loc>{{ site.url }}/stats/</loc><changefreq>daily</changefreq><priority>0.4</priority></url>
  <url><loc>{{ site.url }}/videos/</loc><changefreq>daily</changefreq><priority>0.6</priority></url>
  <url><loc>{{ site.url }}/search/</loc><changefreq>monthly</changefreq><priority>0.5</priority></url>
</urlset>
