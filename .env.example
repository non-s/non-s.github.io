# Required GitHub Actions secrets
PEXELS_API_KEY=

# OAuth JSON printed by auth_youtube.py. This is not an API key.
YOUTUBE_TOKEN=

# Used only while running auth_youtube.py locally.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# AI text providers: configure at least one
MISTRAL_API_KEY=
CEREBRAS_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# Upload visibility: public | unlisted | private
YOUTUBE_PRIVACY=public
MAX_SHORTS_PER_RUN=1
CHANNEL_WATERMARK=
PANIC_HALT=

# Optional zero-cost quality extensions
PIXABAY_API_KEY=
AUDIO_LIBRARY_MANIFEST=_data/audio_library_manifest.json
COQUI_TTS_COMMAND=
COQUI_TTS_MODEL=
EXPERIMENTS_FILE=_data/experiments.json
VARIANT_ASSIGNMENTS_FILE=_data/analytics/variant_assignments.jsonl
