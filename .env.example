# ============================================================
# GlobalBR News — GitHub Actions Secrets
# Copy this file as reference when setting up the repository.
# All values below must be added as GitHub repository secrets
# at: Settings → Secrets and variables → Actions → New repository secret
# ============================================================

# --- REQUIRED --- #

# Mistral La Plateforme API key — drives every AI call in the pipeline
# (titles, summaries, key points, FAQ, translation, video metadata).
# Site stops publishing without this. Get at: https://console.mistral.ai
MISTRAL_API_KEY=

# --- OPTIONAL: search-engine indexing --- #

# Google Search Console Indexing API (speeds up Google indexing).
# Service-account JSON; paste the entire JSON as a single-line string.
# Get at: https://search.google.com/search-console (API quotas apply).
GOOGLE_INDEXING_CREDENTIALS=

# Bing Webmaster Tools API key (submit URLs to Bing).
# Get at: https://www.bing.com/webmasters
BING_API_KEY=

# IndexNow key (instant indexing for Bing + Yandex).
# Generate any random string, then host it at https://yourdomain/YOUR_KEY.txt
INDEXNOW_KEY=

# --- OPTIONAL: YouTube auto-upload (youtube-bot.yml) --- #

# OAuth2 token JSON for upload_youtube.py.
# Run auth_youtube.py locally once to generate token.json, paste content here.
# Scopes used: youtube.upload + youtube (playlists).
YOUTUBE_TOKEN=

# --- OPTIONAL: Newsletter (newsletter.yml) --- #

# Mailchimp Marketing API.
# Get at: https://mailchimp.com/developer/marketing/api/
MAILCHIMP_API_KEY=
MAILCHIMP_AUDIENCE_ID=
MAILCHIMP_SERVER=us1

# --- TUNING: fetch_news.py (all have defaults) --- #

MISTRAL_MODEL=mistral-small-latest    # any chat-completion model on La Plateforme
MISTRAL_MIN_INTERVAL=8                # seconds between Mistral calls (rate limit)
FETCH_MAX_PER_FEED=10                 # max items processed per RSS feed per run
FETCH_MAX_PER_RUN=100                 # global cap of items processed per run
FETCH_SLEEP_BETWEEN_FEEDS=0           # politeness delay between feeds (seconds)
FETCH_FEED_WORKERS=10                 # parallel feed workers (ThreadPoolExecutor)
FETCH_QUALITY_THRESHOLD=6             # 0-10 AI quality gate (anything below dropped)
FETCH_TIMEOUT_S=3300                  # max wall-clock seconds for the whole run
POST_MAX_AGE_DAYS=                    # if set, delete posts older than N days

# --- TUNING: audit_site.py --- #

AUDIT_MAX_AGE_DAYS=90          # posts older than this flagged as "old"
AUDIT_MIN_TITLE_CHARS=20       # min title length before flagged
AUDIT_MIN_DESC_CHARS=50        # min description length before flagged
AUDIT_MIN_POSTS_PER_CAT=3      # categories with fewer posts flagged as thin

# --- TUNING: send_newsletter.py --- #

NEWSLETTER_MIN_POSTS=3         # minimum posts required to send newsletter
NEWSLETTER_MAX_POSTS=10        # maximum posts included in newsletter

# --- TUNING: create_monthly_roundup.py --- #

ROUNDUP_MIN_POSTS=5            # minimum posts in month to generate roundup

# --- TUNING: video posting (create_video_blog_post.py) --- #

VIDEO_LOOKBACK_H=2             # hours back to look for new videos
VIDEO_MAX_POSTS=5              # max videos to post per run

# --- TUNING: shorts pipeline (generate_shorts.py) --- #

MAX_SHORTS_PER_RUN=3           # max Shorts generated per youtube-bot run

# --- TUNING: optimize_images.py --- #

IMAGE_WEBP_QUALITY=82          # WebP quality (1-100, higher = bigger file)
IMAGE_WEBP_METHOD=6            # WebP compression method (0=fast, 6=slowest/smallest)
IMAGES_DIR=assets/images/posts # directory to scan for images

# --- TUNING: generate_audio.py --- #

AUDIO_MAX_PER_RUN=             # if set, cap MP3 generations per run
