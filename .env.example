# Required GitHub Actions secrets

# OAuth JSON printed by auth_youtube.py. This is not an API key.
YOUTUBE_TOKEN=

# Used only while running auth_youtube.py locally.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# AI text providers: configure at least one
MISTRAL_API_KEY=
CEREBRAS_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
PEXELS_API_KEY=

# Upload visibility: public | unlisted | private
YOUTUBE_PRIVACY=public
MAX_SHORTS_PER_RUN=1
QUEUE_TARGET_PENDING=24
PUBLISH_BACKFILL_QUEUE_TARGET=24
PUBLISH_BACKFILL_READY_TARGET=1
PUBLISH_BACKFILL_PENDING_BATCH=12
PUBLISH_HEARTBEAT_RUNTIME_MINUTES=170
PUBLISH_HEARTBEAT_DISPATCH_MINUTE=6
PUBLISH_HEARTBEAT_RECENT_RUN_TOLERANCE_MINUTES=10
YOUTUBE_DESCRIPTION_MODE=empty
YOUTUBE_SCHEDULE_UPLOADS=0
YOUTUBE_SCHEDULE_START_UTC=
YOUTUBE_SCHEDULE_SLOTS_UTC=
YOUTUBE_SCHEDULE_OFFSET=0
CHANNEL_WATERMARK=
PANIC_HALT=

# Optional zero-cost quality extensions
BROLL_SOURCE_MODE=pexels
BROLL_DOWNLOAD_MAX_BYTES=94371840
COQUI_TTS_COMMAND=
COQUI_TTS_MODEL=
COQUI_TTS_LOCALE_ARG=0
EXPERIMENTS_FILE=_data/experiments.json
VARIANT_ASSIGNMENTS_FILE=_data/analytics/variant_assignments.jsonl

# Adaptive publish cadence
ADAPTIVE_CADENCE_ENABLED=1
ALLOW_FLEX_SLOT=0
FLEX_SLOT_UTC=
MIN_SLOT_PUBLISH_SCORE=72
MIN_QUEUE_OPPORTUNITY_SCORE=50
PUBLISH_RECOVERY_DELAY_MINUTES=40

# Shorts Reach / free freshness / opening quality
STUDIO_REACH_IMPORT_ENABLED=1
STUDIO_REACH_IMPORT_PATH=_data/studio_reach_exports
TOPIC_FRESHNESS_ENABLED=1
OPENING_AUDIT_ENABLED=1
OPENING_AUDIT_STRICT=1
OPENING_MIN_SCORE=72
OPENING_GATE_MODE=warn
OPENING_GATE_MIN_SCORE=78
FACT_GUARD_MODE=block
RIGHTS_GUARD_MODE=block
ORIGINALITY_PACK_MODE=warn
OPS_GUARDIAN_ENFORCE=1

# Post-upload growth loop
SESSION_GRAPH_ENABLED=1
COMMENT_TO_SHORT_ENABLED=1
COMMENT_TO_SHORT_MIN_SCORE=64
COMMENT_TO_SHORT_MAX_ITEMS=6

# API quota ledger / guard
# YouTube videos.insert calls use their own daily upload bucket. The 10000-unit
# quota still guards non-upload calls such as thumbnails, playlists and analytics.
QUOTA_GUARD_ENABLED=1
QUOTA_GUARD_MODE=block
UPLOAD_IDEMPOTENCY_MODE=block
UPLOAD_SLOT_IDEMPOTENCY_MODE=block
MEDIA_LIFECYCLE_CLEANUP=1
QUOTA_GUARD_MAX_DAILY_RATIO=0.95
QUOTA_LEDGER_ENABLED=1
YOUTUBE_DAILY_QUOTA_BUDGET=10000
YOUTUBE_DAILY_UPLOAD_BUDGET=100

# Optional analytics backfill / repo hygiene
YOUTUBE_REPORTING_ENABLED=0
WAREHOUSE_COMPACTION_ENABLED=1
SEO_METADATA_LINT_ENABLED=1
SEO_METADATA_LINT_STRICT=0
MUSIC_BED_ENABLED=0
MUSIC_BED_CANARY_PERCENT=5
