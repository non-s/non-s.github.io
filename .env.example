# ============================================================
# GlobalBR News — GitHub Actions Secrets
# Copy this file as reference when setting up the repository.
# All values below must be added as GitHub repository secrets
# at: Settings → Secrets and variables → Actions → New repository secret
# ============================================================

# --- REQUIRED --- #

# Groq API (primary AI for content generation — free tier available)
# Get at: https://console.groq.com
GROQ_API_KEY=

# Google Gemini API (fallback AI — free tier available)
# Get at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Bluesky credentials
# Handle: yourname.bsky.social
# App password: Settings → Privacy and Security → App passwords
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# --- OPTIONAL --- #

# Google Search Console Indexing API (speeds up Google indexing)
# Service account JSON — get at: https://search.google.com/search-console
# Paste the entire JSON content as a single-line string
GOOGLE_INDEXING_CREDENTIALS=

# Bing Webmaster Tools API key (submit URLs to Bing)
# Get at: https://www.bing.com/webmasters
BING_API_KEY=

# IndexNow key (instant indexing for Bing + Yandex)
# Generate any random string, then host it at https://yourdomain/YOUR_KEY.txt
INDEXNOW_KEY=

# YouTube OAuth2 token (for auto-uploading videos)
# Run auth_youtube.py locally once to generate token.json, then paste its content here
YOUTUBE_TOKEN=

# Mailchimp newsletter integration
# Get at: https://mailchimp.com/developer/marketing/api/
MAILCHIMP_API_KEY=
MAILCHIMP_AUDIENCE_ID=
MAILCHIMP_SERVER=us1

# DeepL API for Portuguese translation (free tier: 500k chars/month)
# Get at: https://www.deepl.com/pro-api
DEEPL_API_KEY=
