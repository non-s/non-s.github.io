# ============================================================
# Wild Brief — GitHub Actions Secrets (animal Shorts pipeline)
# Set every secret below at:
#   Settings → Secrets and variables → Actions → New repository secret
# ============================================================

# --- REQUIRED --- #

# Mistral La Plateforme API key — primary AI provider for the
# fun-fact narration script.
# Get one at https://console.mistral.ai (free tier: 500k tokens/mo).
MISTRAL_API_KEY=

# Pexels API key — REQUIRED. Drives the discovery layer (animal
# clips) AND the per-Short b-roll fetcher. Without this, fetch_animals
# returns exit 2 and no queue is produced.
# Get one at https://www.pexels.com/api/new/  (200 req/h, 20k/mo).
PEXELS_API_KEY=

# TikTok Open API credentials (Login Kit + Content Posting API).
# Create a developer app at https://developers.tiktok.com/ and copy
# the client key + secret. The redirect URI must be set to
# http://localhost:8080/callback (matches auth_tiktok.py).
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# OAuth token JSON for TikTok Content Posting + analytics. Run
# `python auth_tiktok.py` locally once to generate tiktok_token.json,
# then paste the entire JSON as a single-line string here.
# Scopes needed: video.publish, video.upload, video.list, user.info.basic
TIKTOK_TOKEN=

# --- OPTIONAL: AI fallback chain --- #
#
# Each provider below is a free-tier API. Configuring even ONE of them
# adds a parachute when Mistral rate-limits or 5xxs. The chain fires in
# order: Mistral → Cerebras → Gemini → Groq. First success wins.

# Cerebras — 1M tokens/DAY free tier, OpenAI-compatible API.
# Sign up at https://cloud.cerebras.ai (no credit card).
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama-3.3-70b           # any model on the free tier

# Google Gemini — 15 RPM, 1,500 req/day free on flash-lite.
# Sign up at https://aistudio.google.com/apikey (no credit card).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite

# Groq — ~14k req/day free, very fast inference (sub-second usually).
# Sign up at https://console.groq.com (no credit card).
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- TUNING: fetch_animals.py --- #

MISTRAL_MODEL=mistral-small-latest    # any chat-completion model on La Plateforme
MISTRAL_MIN_INTERVAL=8                # seconds between Mistral calls (rate limit)
MISTRAL_429_CIRCUIT_THRESHOLD=3       # in-run breaker after N consecutive 429 give-ups
ANIMALS_MAX_PER_TOPIC=4               # Pexels clips fetched per topic per run
ANIMALS_KEEP_DAYS=14                  # prune consumed queue entries older than this

# --- AI cache (saves Mistral / fallback quota across runs) --- #
AI_CACHE_ENABLED=1                    # 0 to disable the disk cache (debug only)
AI_CACHE_TTL_DAYS=30                  # how long a cached response stays valid
AI_CACHE_PATH=_data/ai_cache.jsonl    # JSONL file path; safe to delete to force rebuild

# --- B-roll discovery cache (Pexels query results) --- #
BROLL_CACHE_DIR=_data/broll_cache     # discovery cache TTL is 7 days

# --- Captions (word-level burned subtitles) --- #
# Captions are the single biggest retention lever on muted-autoplay
# Shorts (+18% watch time documented). The pipeline uses Groq Whisper
# (free, 2000 req/day, sub-second). Reuses GROQ_API_KEY above.
# If GROQ_API_KEY is unset, faster-whisper runs locally on the runner —
# pip install faster-whisper (already in the workflow's install step).
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# --- A/B experiments --- #
EXPERIMENTS_FILE=_data/analytics/experiments.json
EXPERIMENT_MIN_SAMPLES=8               # min observations per variant before declaring a winner

# --- Music bed (Pixabay CC0 background music) --- #
MUSIC_BED_ENABLED=1                    # 0 to disable music mix entirely
MUSIC_BED_VOLUME=-22                   # dB below TTS (-22 = subtle, -18 = punchier)
MUSIC_CACHE_DIR=_data/music_cache

# --- Brand watermark --- #
CHANNEL_WATERMARK=@wildbrief_x         # TikTok handle drawn upper-right on every Short.
                                       # The TikTok channel is https://www.tiktok.com/@wildbrief_x
                                       # (display name "Wild Brief").

# --- TikTok upload tuning --- #
# Publish mode:
#   direct → publishes the video immediately (Content Posting API).
#            Requires the TikTok app to be approved for `video.publish`.
#   inbox  → drops the video as a draft inside the TikTok mobile app
#            (operator taps Publish from the phone).
# The uploader auto-falls-back from direct→inbox if TikTok rejects the
# request with "scope_not_authorized" / "unaudited_client" — so leaving
# this on `direct` is safe even pre-review.
TIKTOK_PUBLISH_MODE=direct             # direct | inbox
# Privacy level (Direct Post only):
#   PUBLIC_TO_EVERYONE       — visible on the For You feed (audited apps)
#   MUTUAL_FOLLOW_FRIENDS    — followers + followings only
#   SELF_ONLY                — private, only visible to you (sandbox default)
# Unaudited apps can ONLY use SELF_ONLY or MUTUAL_FOLLOW_FRIENDS. Set
# this to PUBLIC_TO_EVERYONE after TikTok approves your app for
# unrestricted publishing.
TIKTOK_PRIVACY=PUBLIC_TO_EVERYONE      # PUBLIC_TO_EVERYONE | MUTUAL_FOLLOW_FRIENDS | SELF_ONLY
TIKTOK_DISABLE_COMMENT=0               # 1 to disable comments per post
TIKTOK_DISABLE_DUET=0                  # 1 to disable Duet per post
TIKTOK_DISABLE_STITCH=0                # 1 to disable Stitch per post

# --- Velocity tracker --- #
VELOCITY_LOG=_data/velocity.jsonl

# --- TikTok posts ledger --- #
TIKTOK_QUOTA_LOG=_data/tiktok_quota_log.jsonl
TIKTOK_QUOTA_DAILY=30                  # TikTok caps unaudited apps at 30 posts/day/user
TIKTOK_QUOTA_WARN_AT=0.80              # warn at 80 % of daily cap

# --- AI provider success-rate tracking --- #
PROVIDER_STATS_LOG=_data/provider_stats.jsonl
PROVIDER_STATS_WINDOW=50                # # of recent calls to average per provider

# --- Kill switch --- #
# Set to 1 (or commit `_data/PANIC_HALT`) to halt every generator + uploader
# before any expensive work. Use during emergencies (channel strike,
# AI hallucination spree, runaway costs).
PANIC_HALT=

# --- Host persona + branding --- #
# Drop a `_data/host_persona.json` to override defaults piecewise.
# Defaults shipped: name="Alex", handle="wildbrief_x", display "Wild Brief".
HOST_PERSONA_FILE=_data/host_persona.json

# Channel memory: bot keeps a JSONL of past Shorts so the AI can
# reference prior coverage ("last week I covered X").
CHANNEL_MEMORY_LOG=_data/channel_memory.jsonl
CHANNEL_MEMORY_LOOKBACK_DAYS=30
CHANNEL_MEMORY_MAX_ENTRIES=500

# Pre-rendered intro/outro audio + branded title cards cached on disk.
INTRO_OUTRO_CACHE_DIR=_data/intro_outro_cache
INTRO_OUTRO_ENABLED=1
BRAND_CARD_CACHE=_data/brand_card_cache
BRAND_CARDS_ENABLED=1

# --- TUNING: Shorts pipeline (generate_shorts.py) --- #

MAX_SHORTS_PER_RUN=1                  # max Shorts per tiktok-bot run
                                      # (5 runs/day × 1 = 5 Shorts/day,
                                      #  17 % of TikTok's 30/day unaudited cap)
TTS_TIMEOUT_S=45                      # edge-tts hard timeout per Short

# --- TUNING: tiktok_analytics.py --- #

ANALYTICS_LOOKBACK_MIN=1              # ignore Shorts younger than this (days)
ANALYTICS_LOOKBACK_MAX=30             # ignore Shorts older than this (days)
