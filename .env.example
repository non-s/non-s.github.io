# ============================================================
# GlobalBR News — GitHub Actions Secrets (Shorts-only pipeline)
# Set every secret below at:
#   Settings → Secrets and variables → Actions → New repository secret
# ============================================================

# --- REQUIRED --- #

# Mistral La Plateforme API key — primary AI provider for title/script.
# Get one at https://console.mistral.ai (free tier: 500k tokens/mo).
MISTRAL_API_KEY=

# OAuth2 token JSON for YouTube upload + Analytics. Run
# `python auth_youtube.py` locally once to generate token.json, then
# paste the entire JSON as a single-line string here.
# Scopes needed: youtube.upload, youtube (playlists+comments),
#                youtube.readonly + yt-analytics.readonly (for the
#                analytics workflow).
YOUTUBE_TOKEN=

# --- OPTIONAL: AI fallback --- #

# Cerebras API key — 1M tokens/DAY free tier. ai_helper.py falls back
# to Cerebras automatically when Mistral 429s through its 3 retries.
# Without this set, the fallback is skipped silently. Get a key at
# https://cloud.cerebras.ai (no credit card, OpenAI-compatible API).
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama-3.3-70b           # any model on the free tier

# --- TUNING: fetch_news.py --- #

MISTRAL_MODEL=mistral-small-latest    # any chat-completion model on La Plateforme
MISTRAL_MIN_INTERVAL=8                # seconds between Mistral calls (rate limit)
FETCH_MAX_PER_FEED=10                 # max items processed per RSS feed per run
FETCH_MAX_PER_RUN=100                 # global cap of stories considered per run
FETCH_SLEEP_BETWEEN_FEEDS=0           # politeness delay between feeds (seconds)
FETCH_FEED_WORKERS=10                 # parallel feed workers (ThreadPoolExecutor)
FETCH_QUALITY_THRESHOLD=6             # 0-10 AI quality gate (anything below dropped)
FETCH_TIMEOUT_S=3300                  # max wall-clock seconds for the whole run

# --- TUNING: Shorts pipeline (generate_shorts.py) --- #

MAX_SHORTS_PER_RUN=1                  # max Shorts per youtube-bot run
                                      # (3 runs/day × 1 = 3 Shorts/day)
TTS_TIMEOUT_S=45                      # edge-tts hard timeout per Short

# --- TUNING: youtube_analytics.py --- #

ANALYTICS_LOOKBACK_MIN=1              # ignore Shorts younger than this (days)
ANALYTICS_LOOKBACK_MAX=30             # ignore Shorts older than this (days)
