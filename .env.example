# Required GitHub Actions secrets

# OAuth JSON printed by auth_youtube.py. This is not an API key.
YOUTUBE_TOKEN=

# Used only while running auth_youtube.py locally.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# Lofi pipeline's visual source (anime/illustrated b-roll)
PIXABAY_API_KEY=

# Only needed for the 24/7 live relay (live-stream.yml)
YOUTUBE_STREAM_KEY=

# Optional: enables AI-assisted title/description translation in
# upload_youtube.py. Degrades to English-only when unset.
MISTRAL_API_KEY=
CEREBRAS_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# Upload visibility: public | unlisted | private
YOUTUBE_PRIVACY=public
YOUTUBE_DESCRIPTION_MODE=full
CHANNEL_PLAYLIST_PREFIX=
CHANNEL_DEFAULT_HASHTAGS=#Shorts,#lofi,#chillbeats
CHANNEL_PLAYLIST_DESCRIPTION=Lofi Shorts grouped for easier binge watching.
PUBLISH_RECOVERY_DELAY_MINUTES=40
PUBLISH_HEARTBEAT_RECENT_RUN_TOLERANCE_MINUTES=10
PANIC_HALT=

# Adaptive publish cadence over the canonical 24/day UTC grid
ADAPTIVE_CADENCE_ENABLED=1
ALLOW_FLEX_SLOT=0
FLEX_SLOT_UTC=
MIN_SLOT_PUBLISH_SCORE=72
MIN_QUEUE_OPPORTUNITY_SCORE=50

# Optional: publish as scheduled (private + publishAt) instead of immediate public
YOUTUBE_SCHEDULE_UPLOADS=0
YOUTUBE_SCHEDULE_START_UTC=
YOUTUBE_SCHEDULE_SLOTS_UTC=
YOUTUBE_SCHEDULE_OFFSET=0

# Master switch for the hourly lofi Shorts publisher
YOUTUBE_PUBLISHING_ENABLED=0

# Shorts Reach / Reporting API analytics (manual CSV import)
STUDIO_REACH_IMPORT_ENABLED=1
YOUTUBE_REPORTING_ENABLED=0

# API quota ledger / guard
# YouTube videos.insert calls use their own daily upload bucket. The 10000-unit
# quota still guards non-upload calls such as thumbnails, playlists and analytics.
QUOTA_GUARD_ENABLED=1
QUOTA_GUARD_MODE=block
UPLOAD_IDEMPOTENCY_MODE=block
UPLOAD_SLOT_IDEMPOTENCY_MODE=block
MEDIA_LIFECYCLE_CLEANUP=1
QUOTA_GUARD_MAX_DAILY_RATIO=0.95
QUOTA_LEDGER_ENABLED=1
YOUTUBE_DAILY_QUOTA_BUDGET=10000
YOUTUBE_DAILY_UPLOAD_BUDGET=100

# Ops alert (GitHub Issues) for failed critical workflows
OPS_ALERTS_ENABLED=1

# Community engagement: comment replies + weekly Community post draft.
# Independent of YOUTUBE_PUBLISHING_ENABLED -- see README.md.
COMMUNITY_ENGAGEMENT_ENABLED=0
COMMENT_REPLY_MAX_PER_RUN=15

# Storm Ambience pillar (real rain/thunder ambience, not the "anime lofi"
# pillar): independent of YOUTUBE_PUBLISHING_ENABLED -- see README.md.
STORM_AMBIENCE_ENABLED=0
STORM_MIN_DURATION_MINUTES=45
STORM_MAX_DURATION_MINUTES=75
STORM_MUSIC_LAYER_PROBABILITY=0.35

# Which pillar scripts/live_stream_dynamic.py broadcasts: lofi or storm.
LIVE_CONTENT_PILLAR=lofi
