---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0"
     xmlns:itunes="http://www.itunes.com/dtds/podcast-1.0.dtd"
     xmlns:content="http://purl.org/rss/1.0/modules/content/"
     xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>GlobalBR News — Audio Articles</title>
    <link>{{ site.url }}/podcast-articles.xml</link>
    <language>en-us</language>
    <description>Each GlobalBR News article narrated by AI voice — listen to the world's news on the go. Updated every hour.</description>
    <copyright>© {{ 'now' | date: '%Y' }} GlobalBR News</copyright>
    <managingEditor>bot@globalbrnews.com (GlobalBR News Bot)</managingEditor>
    <lastBuildDate>{{ site.time | date_to_rfc822 }}</lastBuildDate>
    <ttl>30</ttl>

    <image>
      <url>{{ '/assets/images/logo.png' | absolute_url }}</url>
      <title>GlobalBR News — Audio Articles</title>
      <link>{{ site.url }}</link>
    </image>

    <itunes:author>GlobalBR News</itunes:author>
    <itunes:summary>AI-narrated audio version of every GlobalBR News article — listen to world news, politics, tech, science and more on the go.</itunes:summary>
    <itunes:explicit>false</itunes:explicit>
    <itunes:type>episodic</itunes:type>
    <itunes:category text="News">
      <itunes:category text="Daily News"/>
    </itunes:category>
    <itunes:image href="{{ '/assets/images/logo.png' | absolute_url }}"/>
    <itunes:owner>
      <itunes:name>GlobalBR News</itunes:name>
      <itunes:email>bot@globalbrnews.com</itunes:email>
    </itunes:owner>

    <atom:link href="{{ '/podcast-articles.xml' | absolute_url }}" rel="self" type="application/rss+xml"/>

    {% assign audio_posts = site.posts | where_exp: "p", "p.audio" %}
    {% for post in audio_posts limit:50 %}
    <item>
      <title>{{ post.title | xml_escape }}</title>
      <link>{{ post.url | absolute_url }}</link>
      <guid isPermaLink="true">{{ post.url | absolute_url }}</guid>
      <pubDate>{{ post.date | date_to_rfc822 }}</pubDate>
      <description><![CDATA[{{ post.description | default: post.excerpt | strip_html | truncate: 320 }}]]></description>
      <enclosure url="{{ post.audio | absolute_url }}"
                 type="audio/mpeg"
                 length="0"/>
      {% for cat in post.categories limit:1 %}<category>{{ cat | xml_escape }}</category>{% endfor %}
      <itunes:title>{{ post.title | xml_escape }}</itunes:title>
      <itunes:author>GlobalBR News</itunes:author>
      <itunes:summary>{{ post.description | strip_html | truncate: 320 | xml_escape }}</itunes:summary>
      <itunes:explicit>false</itunes:explicit>
      {% if post.audio_duration %}<itunes:duration>{{ post.audio_duration }}</itunes:duration>{% endif %}
      <itunes:image href="{{ post.image | default: '/assets/images/og-default.jpg' | absolute_url }}"/>
      <itunes:episodeType>full</itunes:episodeType>
    </item>
    {% endfor %}

  </channel>
</rss>
