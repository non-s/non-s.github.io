.env
.env.local
youtube_token.json
client_secret.json
credentials.json
token.pickle
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
.vscode/
.idea/

