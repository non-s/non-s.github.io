_assets/video/animal_broll/*
_assets/audio/animal_jazz/*
_assets/thumbnails/*
!_assets/.gitkeep
!_assets/video/.gitkeep
!_assets/audio/.gitkeep
!_assets/thumbnails/.gitkeep
!_videos/.gitkeep

# Data files that may contain tokens or sensitive counters
_data/*
!_data/.gitkeep

# Logs
*.log
