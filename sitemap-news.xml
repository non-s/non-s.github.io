---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:news="http://www.google.com/schemas/sitemap-news/0.9">
  {% for post in site.posts limit:1000 %}
  <url>
    <loc>{{ post.url | absolute_url }}</loc>
    <news:news>
      <news:publication>
        <news:name>GlobalBR News</news:name>
        <news:language>en</news:language>
      </news:publication>
      <news:publication_date>{{ post.date | date_to_xmlschema }}</news:publication_date>
      <news:title>{{ post.title | xml_escape }}</news:title>
      {% if post.keywords %}<news:keywords>{{ post.keywords | join: ', ' | xml_escape }}</news:keywords>{% endif %}
      {% if post.content_type == 'opinion' %}
      <news:genres>Opinion</news:genres>
      {% elsif post.content_type == 'analysis' %}
      <news:genres>Blog</news:genres>
      {% elsif post.content_type == 'explainer' %}
      <news:genres>Blog</news:genres>
      {% endif %}
    </news:news>
  </url>
  {% endfor %}
</urlset>
